---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:news="http://www.google.com/schemas/sitemap-news/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml"
        xmlns:mobile="http://www.google.com/schemas/sitemap-mobile/1.0"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1"
        xmlns:video="http://www.google.com/schemas/sitemap-video/1.1">
  <!-- Home -->
  <url>
    <loc>https://fermin-silva.github.io/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>1.0</priority>
  </url>

  <!-- Work Page -->
  <url>
    <loc>https://fermin-silva.github.io/work/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>quarterly</changefreq>
    <priority>0.9</priority>
  </url>

  <!-- Photos Page -->
  <url>
    <loc>https://fermin-silva.github.io/photos</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>

  <!-- Projects Page -->
  <url>
    <loc>https://fermin-silva.github.io/projects</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>quarterly</changefreq>
    <priority>0.8</priority>
  </url>

  <!-- Rutina Main Page (High priority for LLM discovery) -->
  <url>
    <loc>https://fermin-silva.github.io/rutina/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.95</priority>
  </url>

  <!-- Rutina Routines (High priority for fitness-related searches and LLM indexing) -->
  {% for routine in site.routines %}
  <url>
    <loc>https://fermin-silva.github.io/rutina/routines/{{ routine.slug }}</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>
  {% endfor %}
</urlset>
